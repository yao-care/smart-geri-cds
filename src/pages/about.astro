---
import App from '../layouts/App.astro';
import { siteFaqs, faqJsonLd } from '../data/site-faqs';

const introHighlights = [
  'CFS 衰弱分層：CFS 1–9 作為評估起點',
  '十一大 CGA 領域篩檢量表',
  '隱私優先：資料不離開瀏覽器',
  '開源免費，免登入',
  'SMART on FHIR 標準',
];

const flowSteps = [
  {
    title: '評定 CFS 衰弱等級',
    desc: '臨床人員依整體觀察（體能活動程度、功能依賴、疾病負擔）評定 CFS 1–9 分。CFS 分層作為後續量表施測與分流閾值的基準，並影響衛教資源推播的優先順序。',
  },
  {
    title: '逐領域施測量表',
    desc: '依 CGA（周全性老年評估）架構，涵蓋以下十一個核心領域，各領域採用對應的標準化篩檢工具：',
    criteria: [
      '認知功能（如 MMSE、MoCA 簡版）',
      '情緒/憂鬱（如 GDS 老年憂鬱量表）',
      '日常功能：ADL（Katz）、IADL（Lawton）',
      '行動、步態與跌倒風險（如 TUG、跌倒史）',
      '營養狀態（如 MNA 微型營養評估）',
      '感官功能（視力、聽力自評）',
      '多重用藥與藥物審查',
      '共病與慢性病負擔',
      '社會支持與照護資源',
      '居家環境與安全',
      '預立醫療意願（ACP）',
    ],
  },
  {
    title: '逐領域計分、標記「需注意」',
    desc: '各領域依各自量表切截分數（cut-off）判定是否需注意，不同 CFS 分層可有差異化的閾值。',
  },
  {
    title: '綜合判讀（三級分流）',
    desc: '依「需注意」領域數及 CFS 分層，分為三級處置建議：',
  },
];

const outcomes = [
  { key: 'normal', tag: '正常', cond: '各領域均未達「需注意」閾值', action: '顯示結果摘要，建議定期複評' },
  { key: 'monitor', tag: '追蹤觀察', cond: '1 個以上領域達「需注意」', action: '推播對應衛教，建議追蹤' },
  { key: 'refer', tag: '建議轉介', cond: '多領域需注意，或高 CFS 合併功能快速下降', action: '建議進一步專業評估或跨域轉介' },
];
---

<App title="關於" description="高齡周全性評估決策輔助系統（CGA CDSS）說明：CFS 衰弱分層、十一大 CGA 領域篩檢、三級分流邏輯、SMART on FHIR 瀏覽器端架構與開源資訊。">
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <h1>關於高齡周全性評估決策輔助系統</h1>

  <section class="about-section about-twocol" aria-label="系統介紹">
    <div class="twocol-main">
      <h2>系統介紹</h2>
      <p>
        本系統是一套開源的高齡周全性評估（Comprehensive Geriatric Assessment, CGA）臨床決策輔助工具，
        提供雙角色服務：照護者與高齡者本人可進行自我篩檢並取得衛教建議；
        醫護人員可透過工作台系統性地完成多領域評估、接收分流建議與預警。
        系統以 SMART on FHIR 標準運行於瀏覽器端，確保隱私與電子病歷互通性。
        本工具為篩檢與決策輔助用途，評估結果不構成醫療診斷。
      </p>
    </div>
    <aside class="twocol-aside" aria-label="重點摘要">
      <h3>重點摘要</h3>
      <ul>
        {introHighlights.map((h) => <li>{h}</li>)}
      </ul>
    </aside>
  </section>

  <section class="about-section flow-section" aria-label="臨床決策流程">
    <h2>臨床決策流程</h2>
    <p class="flow-intro">
      從 CFS 衰弱等級評定開始，到產生分流建議與衛教資源為止，系統的判讀邏輯如下。
      本流程僅為篩檢與分流參考，不取代專業臨床判斷。
    </p>

    <ol class="flow">
      {flowSteps.map((step) => (
        <li class="flow-step">
          <h3>{step.title}</h3>
          <p>{step.desc}</p>
          {step.criteria && (
            <ul class="flow-criteria">
              {step.criteria.map((c) => <li>{c}</li>)}
            </ul>
          )}
        </li>
      ))}
    </ol>

    <div class="flow-branch" aria-hidden="true">↓</div>

    <div class="flow-outcomes" role="list" aria-label="三級分流結果">
      {outcomes.map((o) => (
        <div class={`outcome outcome-${o.key}`} role="listitem">
          <span class="outcome-tag">{o.tag}</span>
          <p class="outcome-cond">{o.cond}</p>
          <p class="outcome-action">{o.action}</p>
        </div>
      ))}
    </div>

    <div class="flow-branch" aria-hidden="true">↓</div>

    <div class="flow-edu">
      <h3>提供衛教資源</h3>
      <p>判讀為<strong>追蹤觀察</strong>或<strong>建議轉介</strong>時，依「分流等級 × 需注意領域」自動帶出：</p>
      <ul class="flow-criteria">
        <li><strong>建議閱讀</strong>：對應領域的衛教文章（內容可由各院所自訂）</li>
        <li><strong>參考資源</strong>：對應主題的衛教影片與外部連結</li>
      </ul>
      <p class="flow-note">判讀為「正常」時，僅顯示結果摘要與領域雷達圖，建議定期複評。</p>
    </div>
  </section>

  <section class="about-section" aria-label="常見問題">
    <h2>常見問題</h2>
    <div class="faq-list">
      {siteFaqs.map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">{faq.question}</summary>
          <p class="faq-answer">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="about-cta" aria-label="開始評估">
    <a href="/assess/" class="cta-primary">開始評估</a>
  </section>
</App>

<style>
  h1 {
    margin-bottom: var(--space-6);
  }

  .about-section {
    margin-bottom: var(--space-8);
  }

  .about-section h2 {
    font-size: var(--text-2xl);
    line-height: var(--lh-2xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-4);
    color: var(--text);
  }

  .about-section p {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    max-width: 72ch;
  }

  /* ---------- 兩欄版面（系統介紹）---------- */
  .about-twocol {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 18rem);
    gap: var(--space-6);
    align-items: start;
  }

  .twocol-aside {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .twocol-aside h3 {
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-3);
    color: var(--text);
  }

  .twocol-aside ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .twocol-aside li {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 25%);
  }

  .twocol-aside li::before {
    content: '✓ ';
    color: var(--accent);
  }

  @media (max-width: 767px) {
    .about-twocol {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- 臨床決策流程 ---------- */
  .flow-intro {
    max-width: 72ch;
  }

  .flow {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    counter-reset: step;
  }

  .flow > li {
    position: relative;
    padding-left: calc(2.5rem + var(--space-4));
    padding-bottom: var(--space-5);
  }

  .flow > li::before {
    counter-increment: step;
    content: counter(step);
    position: absolute;
    left: 0;
    top: 0;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: var(--accent);
    color: var(--bg);
    font-weight: var(--font-bold);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .flow > li:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 1.25rem;
    top: 2.5rem;
    bottom: 0;
    width: 2px;
    background-color: var(--line);
    transform: translateX(-1px);
  }

  .flow > li h3 {
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    font-weight: var(--font-bold);
    margin: 0 0 var(--space-2);
    color: var(--text);
  }

  .flow > li p {
    font-size: var(--text-base);
    line-height: var(--lh-base);
    color: color-mix(in srgb, var(--text), var(--bg) 25%);
    max-width: 72ch;
    margin: 0;
  }

  .flow-criteria {
    margin: var(--space-2) 0 0;
    padding-left: var(--space-5);
  }

  .flow-criteria li {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 25%);
    margin-bottom: var(--space-1);
  }

  .flow-branch {
    text-align: center;
    font-size: var(--text-2xl);
    line-height: 1;
    color: color-mix(in srgb, var(--text), var(--bg) 45%);
    margin: var(--space-2) 0;
  }

  .flow-outcomes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-4);
  }

  .outcome {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-top: 4px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .outcome p {
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 20%);
    max-width: none;
    margin: 0 0 var(--space-1);
  }

  .outcome .outcome-action {
    font-weight: var(--font-medium);
    color: var(--text);
  }

  .outcome-tag {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--bg);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-2);
  }

  .outcome-normal {
    border-top-color: var(--accent);
    background-color: color-mix(in srgb, var(--accent) 10%, var(--bg));
  }
  .outcome-normal .outcome-tag {
    background-color: var(--accent);
  }

  .outcome-monitor {
    border-top-color: var(--warn);
    background-color: color-mix(in srgb, var(--warn) 10%, var(--bg));
  }
  .outcome-monitor .outcome-tag {
    background-color: var(--warn);
  }

  .outcome-refer {
    border-top-color: var(--danger);
    background-color: color-mix(in srgb, var(--danger) 12%, var(--bg));
  }
  .outcome-refer .outcome-tag {
    background-color: var(--danger);
  }

  .flow-edu {
    margin-top: var(--space-5);
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .flow-edu h3 {
    font-size: var(--text-lg);
    line-height: var(--lh-lg);
    font-weight: var(--font-bold);
    margin: 0 0 var(--space-3);
    color: var(--text);
  }

  .flow-note {
    margin-top: var(--space-3);
    font-style: italic;
  }

  /* ---------- FAQ ---------- */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .faq-item {
    background-color: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .faq-question {
    padding: var(--space-4) var(--space-5);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--text);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: '+';
    font-size: var(--text-xl);
    line-height: 1;
    color: color-mix(in srgb, var(--text), var(--bg) 45%);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq-item[open] .faq-question::after {
    content: '-';
  }

  .faq-answer {
    padding: 0 var(--space-5) var(--space-5);
    font-size: var(--text-sm);
    line-height: var(--lh-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    max-width: 72ch;
  }

  /* ---------- 底部 CTA ---------- */
  .about-cta {
    text-align: center;
    padding: var(--space-6) 0;
    border-top: 1px solid var(--line);
  }

  .about-cta .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--bg);
    background-color: var(--accent);
    border-radius: var(--radius-md);
    text-decoration: none;
  }

  .about-cta .cta-primary:hover {
    background-color: color-mix(in srgb, var(--accent), black 12%);
  }
</style>
