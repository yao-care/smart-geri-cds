---
import App from '../layouts/App.astro';
import ServerConfig from '../components/fhir/ServerConfig.svelte';
import WebhookConfig from '../components/settings/WebhookConfig.svelte';
import NotificationPrefs from '../components/settings/NotificationPrefs.svelte';
import EducationManager from '../components/settings/EducationManager.svelte';
import RecommendationsManager from '../components/settings/RecommendationsManager.svelte';
import SystemGuide from '../components/settings/SystemGuide.svelte';

const tabs = [
  { id: 'guide', label: '系統說明' },
  { id: 'fhir', label: 'FHIR Server 設定' },
  { id: 'webhook', label: 'Webhook 設定' },
  { id: 'notification', label: '通知偏好' },
  { id: 'education', label: '衛教管理' },
  { id: 'recommendations', label: '評估推薦' },
];
---

<App title="系統設定" description="FHIR Server、Webhook、通知偏好與衛教設定">
  <a href="/workspace/" class="back-to-workspace">&larr; 返回工作台</a>
  <h1>系統設定</h1>

  <div class="tabs">
    {tabs.map((tab, index) => (
      <Fragment>
        <input
          type="radio"
          id={`tab-${tab.id}`}
          name="settings-tab"
          class="tab-input"
          checked={index === 0}
        />
        <label for={`tab-${tab.id}`} class="tab-label">{tab.label}</label>
      </Fragment>
    ))}

    <section id="panel-fhir" class="tab-panel" aria-label="FHIR Server 設定">
      <h2>FHIR Server 設定</h2>
      <ServerConfig client:idle />
    </section>
    <section id="panel-webhook" class="tab-panel" aria-label="Webhook 設定">
      <h2>Webhook 設定</h2>
      <WebhookConfig client:idle />
    </section>
    <section id="panel-notification" class="tab-panel" aria-label="通知偏好">
      <h2>通知偏好</h2>
      <NotificationPrefs client:idle />
    </section>
    <section id="panel-education" class="tab-panel" aria-label="衛教管理">
      <h2>衛教管理</h2>
      <EducationManager client:idle />
    </section>
    <section id="panel-recommendations" class="tab-panel" aria-label="評估推薦">
      <h2>評估推薦清單</h2>
      <RecommendationsManager client:idle />
    </section>
    <section id="panel-guide" class="tab-panel" aria-label="系統說明">
      <SystemGuide client:idle />
    </section>
  </div>
</App>

<style>
  .back-to-workspace {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    text-decoration: none;
    margin-bottom: var(--space-4);
  }

  .back-to-workspace:hover {
    color: var(--accent);
  }

  h1 {
    margin-bottom: var(--space-6);
  }

  .tabs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0;
    border-bottom: 1px solid var(--line);
  }

  .tab-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .tab-label {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: color-mix(in srgb, var(--text), var(--bg) 30%);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
    text-align: center;
  }

  .tab-label:hover {
    color: var(--text);
  }

  .tab-panel {
    display: none;
    grid-column: 1 / -1;
    padding: var(--space-6) 0;
  }

  .tab-panel h2 {
    font-size: var(--text-xl);
    line-height: var(--lh-xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--space-4);
  }

  /* CSS-only tab activation */
  #tab-fhir:checked ~ #panel-fhir,
  #tab-rules:checked ~ #panel-rules,
  #tab-webhook:checked ~ #panel-webhook,
  #tab-notification:checked ~ #panel-notification,
  #tab-model:checked ~ #panel-model,
  #tab-education:checked ~ #panel-education,
  #tab-recommendations:checked ~ #panel-recommendations,
  #tab-guide:checked ~ #panel-guide {
    display: block;
  }

  #tab-fhir:checked ~ label[for="tab-fhir"],
  #tab-rules:checked ~ label[for="tab-rules"],
  #tab-webhook:checked ~ label[for="tab-webhook"],
  #tab-notification:checked ~ label[for="tab-notification"],
  #tab-model:checked ~ label[for="tab-model"],
  #tab-education:checked ~ label[for="tab-education"],
  #tab-recommendations:checked ~ label[for="tab-recommendations"],
  #tab-guide:checked ~ label[for="tab-guide"] {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

</style>
