---
import Base from '../../layouts/Base.astro';
import Header from '../../components/blocks/Header.astro';
import ResultViewWrapper from '../../components/assess/ResultViewWrapper.svelte';
---

<Base title="評估結果" description="高齡周全性評估（CGA）結果與分流建議">
  <meta slot="head" name="referrer" content="no-referrer" />
  <div class="app-layout">
    <Header />
    <main id="main-content" class="app-main">
      <ResultViewWrapper client:load />
    </main>
  </div>
</Base>

<style>
  .app-layout {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .app-main {
    flex: 1;
    padding: var(--space-6) var(--space-4);
    max-width: 960px;
    width: 100%;
    margin: 0 auto;
  }
</style>
