---
import Base from '../layouts/Base.astro';
import Header from '../components/blocks/Header.astro';
import AssessmentShell from '../components/assess/AssessmentShell.svelte';
import { getCollection } from 'astro:content';
import { toScaleDefs } from '../lib/scales/load-scales';

const scaleEntries = await getCollection('scales');
const scales = toScaleDefs(scaleEntries);
---

<Base title="開始評估" description="高齡周全性評估（CGA）智慧分流">
  <div class="app-layout">
    <Header />
    <main id="main-content" class="app-main" data-pagefind-body>
      <AssessmentShell client:load {scales} />
    </main>
  </div>
</Base>

<style>
  .app-layout {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  .app-main {
    flex: 1;
    padding: var(--space-6) var(--space-4);
    max-width: 960px;
    width: 100%;
    margin: 0 auto;
  }
</style>
