---
import OfflineBanner from '../components/common/OfflineBanner.svelte';
import { BASE_PATH } from '../../scripts/base.mjs';
import { CONTENT_SECURITY_POLICY } from '../lib/security/csp';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const canonicalURL = canonical
  ? new URL(canonical, Astro.site)
  : new URL(Astro.url.pathname, Astro.site);
const fullTitle = `${title} | 高齡周全性評估`;
const base = BASE_PATH;

import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* CSP 僅於正式建置投遞：dev 端會擋掉 Vite HMR 的 ws 連線。
        meta 不支援 frame-ancestors，點擊劫持改由下方 frame-busting 緩解。 */}
    {import.meta.env.PROD && (
      <meta http-equiv="Content-Security-Policy" content={CONTENT_SECURITY_POLICY} />
    )}
    {/* 點擊劫持緩解（10020）：GitHub Pages 無法送 X-Frame-Options。被非同源
        嵌入時隱藏內容並嘗試跳出框架；未被嵌入則完全不影響（含 no-JS 使用者）。 */}
    <script is:inline>
      if (window.self !== window.top) {
        document.documentElement.style.visibility = 'hidden';
        try {
          window.top.location = window.self.location;
        } catch (e) {
          /* 跨來源無法存取 top.location：頁面維持隱藏 */
        }
      }
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="manifest" href={base + '/manifest.json'} />
    <link rel="icon" type="image/png" sizes="32x32" href={base + '/icons/favicon-32.png'} />
    <link rel="icon" type="image/png" sizes="16x16" href={base + '/icons/favicon-16.png'} />
    <link rel="apple-touch-icon" sizes="180x180" href={base + '/icons/apple-touch-icon.png'} />
    <meta name="theme-color" content="#3d6b54" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={new URL(base + '/icons/icon-512.png', Astro.site).href} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(base + '/icons/icon-512.png', Astro.site).href} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">跳至主要內容</a>
    <OfflineBanner client:idle />
    <slot />
    <script src="../lib/sw/register-entry.ts"></script>
  </body>
</html>
